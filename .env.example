# Example Environment Configuration
# Copy this file to .env and fill in your values

# Google Cloud Project Configuration (REQUIRED for BigQuery patent search)
# This is used by BigQueryPatentSearch for billing/quota tracking
GOOGLE_CLOUD_PROJECT=your-project-id-here

# Logging Configuration
# Use WARNING and json for MCP compatibility (less verbose logging)
PATENT_LOG_LEVEL=WARNING
PATENT_LOG_FORMAT=json

# USPTO API (Optional - for USPTO Open Data Portal)
# Get your API key from: https://data.uspto.gov/myodp
USPTO_API_KEY=

# Performance Configuration
PATENT_ENABLE_METRICS=true
PATENT_OPERATION_TIMEOUT=300

# MPEP Search Configuration
PATENT_MPEP_USE_HYDE=false
PATENT_MPEP_DEVICE=cpu

# HyDE Query Expansion Backend
# Set to "api" to use Anthropic/OpenAI for query expansion (consumes API quota)
# Leave unset or empty for rule-based expansion (default, no API cost)
# HYDE_BACKEND=api

# Antecedent Basis Checking (Experimental)
# Enable regex-based "the X" / "said X" antecedent basis check in claims analyzer
# High false positive rate -- findings emitted at LOW confidence, manual review required
# PATENT_ENABLE_ANTECEDENT_CHECK=false

# Windows Git Bash Path (Windows only)
# CLAUDE_CODE_GIT_BASH_PATH=C:\dev\Git\bin\bash.exe
